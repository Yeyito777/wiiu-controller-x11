diff --git a/bdaddr.c b/bdaddr.c
index ef32b27..055109e 100644
--- a/bdaddr.c
+++ b/bdaddr.c
@@ -291,6 +291,21 @@ static int mrvl_write_bd_addr(int dd, bdaddr_t *bdaddr)
 	return 0;
 }
 
+#define OCF_MTK_WRITE_BD_ADDR		0x001a
+static int mtk_write_bd_addr(int dd, bdaddr_t *bdaddr)
+{
+	/* MediaTek runtime/public address override. This is temporary: the
+	 * controller returns to its original address after reset/power cycle.
+	 * Full vendor opcode is 0xfc1a: OGF_VENDOR_CMD + OCF 0x001a.
+	 */
+	if (hci_send_cmd(dd, OGF_VENDOR_CMD, OCF_MTK_WRITE_BD_ADDR,
+								sizeof(*bdaddr), bdaddr) < 0)
+		return -1;
+
+	sleep(1);
+	return 0;
+}
+
 static int st_write_bd_addr(int dd, bdaddr_t *bdaddr)
 {
 	return ericsson_store_in_flash(dd, 0xfe, 6, (uint8_t *) bdaddr);
